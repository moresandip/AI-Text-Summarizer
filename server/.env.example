## server/.env Template
# Get your free GEMINI_API_KEY from https://aistudio.google.com/app/apikey
# Copy this file to .env and fill in your key.

# Required: Your Google Gemini API key
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Recommended model (stable, valid for v1 API)
GEMINI_MODEL=gemini-2.0-flash

# Optional: Server port
PORT=5000

# Optional: Alt OpenAI key as backup
# OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
